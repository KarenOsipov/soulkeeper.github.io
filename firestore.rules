rules_version = '2';
// ══════════════════════════════════════════════════════════════════
//  SoulKeeper — Firestore Security Rules
//  Zero-Knowledge Architecture: data is encrypted on client,
//  these rules enforce access control at the server level.
// ══════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ────────────────────────────────────────────
    // Only the authenticated owner can read/write their own data.
    // Note: even the owner cannot see plaintext (it's AES-256 encrypted).
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Connection requests ───────────────────────────────────────
    // Sender can create; either participant can read/update.
    match /connections/{connId} {
      allow read: if request.auth != null
                  && (resource.data.fromUid == request.auth.uid
                   || resource.data.toUid == request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;

      allow update: if request.auth != null
                    && (resource.data.fromUid == request.auth.uid
                     || resource.data.toUid == request.auth.uid);

      allow delete: if request.auth != null
                    && (resource.data.fromUid == request.auth.uid
                     || resource.data.toUid == request.auth.uid);
    }

    // ── Chat metadata ─────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.users;

      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users;

      // ── Chat messages (subcollection) ─────────────────────────
      // NOTE: all message text is AES-256 encrypted on the client.
      match /messages/{msgId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/chats/$(chatId)).data.users;
      }
    }
  }
}
