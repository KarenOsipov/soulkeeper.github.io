rules_version = '2';
// ══════════════════════════════════════════════════════════════════
//  SoulKeeper — Firestore Security Rules
//  Zero-Knowledge Architecture: data is encrypted on client,
//  these rules enforce access control at the server level.
// ══════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ────────────────────────────────────────────
    // Authenticated users can read (needed to search by connection code).
    // Write access is strictly restricted to the owner.
    // Zero-Knowledge details: sensitive fields (secrets/bio/relatives) are encrypted.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Connection requests ───────────────────────────────────────
    // Read and write connection documents where the user is one of the participants.
    match /connections/{connId} {
      allow read, write: if request.auth != null && 
        (connId.split('_')[0] == request.auth.uid || connId.split('_')[1] == request.auth.uid);
    }

    // ── Chat metadata ─────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.users;

      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users;

      // ── Chat messages (subcollection) ─────────────────────────
      // NOTE: all message text is AES-256 encrypted on the client.
      match /messages/{msgId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/chats/$(chatId)).data.users;
      }
    }
  }
}
